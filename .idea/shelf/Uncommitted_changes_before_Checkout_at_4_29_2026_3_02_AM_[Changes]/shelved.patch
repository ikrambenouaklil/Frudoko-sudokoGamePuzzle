<+><!DOCTYPE html>\r\n<html lang=\"fr\" xmlns:th=\"http://www.thymeleaf.org\"\r\n      xmlns:layout=\"http://www.ultraq.net.nz/thymeleaf/layout\"\r\n      layout:decorate=\"~{fragments/layout}\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Title</title>\r\n    <link rel=\"icon\" th:href=\"@{/images/apple.png}\" type=\"image/png\">\r\n    <th:block layout:fragment=\"extra-css\">\r\n        <link rel=\"stylesheet\" th:href=\"@{/css/frudoko.css}\"/>\r\n    </th:block>\r\n</head>\r\n<body >\r\n\r\n<main layout:fragment=\"content\">\r\n\r\n    <th:block th:replace=\"~{fragments/variables :: vars(~{::section})}\">\r\n        <section class=\"fruit-bg d-flex align-items-center justify-content-center\" style=\"min-height:100vh\">\r\n\r\n\r\n\r\n            <div class=\"auth-card\">\r\n\r\n                <div class=\"text-center mb-4\">\r\n                    <a th:href=\"@{/home}\" class=\"text-decoration-none\">\r\n                        <span style=\"font-size:2.5rem\">\r\n                            <img th:src=\"${apple}\" class=\"fruit-icon\">\r\n                        </span>\r\n                    </a>\r\n                    <h3 class=\"mt-2 text-white fw-bold\">Créer un compte</h3>\r\n                    <p class=\"text-white-50 small\">Rejoignez Frudoko !</p>\r\n                </div>\r\n\r\n                <div th:if=\"${error}\" class=\"alert alert-danger text-center py-2 mb-3 small\" th:text=\"${error}\"></div>\r\n\r\n                <form method=\"post\" th:action=\"@{/register}\" novalidate>\r\n\r\n                    <div class=\"mb-3\">\r\n                        <label class=\"form-label text-white-50 small\">Nom d'utilisateur</label>\r\n                        <input type=\"text\"\r\n                               name=\"username\"\r\n                               class=\"form-control auth-input\"\r\n                               placeholder=\"FruitMaster\"\r\n                               required\r\n                               minlength=\"3\"\r\n                               autocomplete=\"username\"/>\r\n                    </div>\r\n\r\n                    <div class=\"mb-3\">\r\n                        <label class=\"form-label text-white-50 small\">Email</label>\r\n                        <input type=\"email\"\r\n                               name=\"email\"\r\n                               class=\"form-control auth-input\"\r\n                               placeholder=\"votre@email.com\"\r\n                               required\r\n                               autocomplete=\"email\"/>\r\n                    </div>\r\n\r\n                    <div class=\"mb-4\">\r\n                        <label class=\"form-label text-white-50 small\">Mot de passe</label>\r\n                        <div class=\"input-group\">\r\n                            <input type=\"password\"\r\n                                   id=\"passwordInput\"\r\n                                   name=\"password\"\r\n                                   class=\"form-control auth-input\"\r\n                                   placeholder=\"Au moins 6 caractères\"\r\n                                   required\r\n                                   minlength=\"6\"\r\n                                   autocomplete=\"new-password\"\r\n                                   oninput=\"checkStrength(this.value)\"/>\r\n                            <button class=\"btn btn-outline-secondary\"\r\n                                    type=\"button\"\r\n                                    onclick=\"togglePassword('passwordInput')\"\r\n                                    tabindex=\"-1\">\r\n                                <img id=\"eyeIcon\"\r\n                                     th:src=\"${eyes}\"\r\n                                     th:attr=\"data-open=${eyes}, data-close=@{/images/close-eye.png}\"\r\n                                     style=\"width:25px;\">\r\n                            </button>\r\n                        </div>\r\n                        <!-- Password strength indicator -->\r\n                        <div class=\"mt-2\">\r\n                            <div id=\"strengthBar\" class=\"strength-bar\"></div>\r\n                            <small id=\"strengthText\" class=\"text-white-50\"></small>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <button type=\"submit\" class=\"btn btn-fruit w-100 py-2 mb-3\">\r\n                        Créer mon compte\r\n                        <img th:src=\"${sparkle}\" style=\"width: 25px ; height:25px;\">\r\n                    </button>\r\n\r\n                </form>\r\n\r\n                <p class=\"text-center text-white-50 small mb-0\">\r\n                    Déjà inscrit ?\r\n                    <a th:href=\"@{/login}\" class=\"text-fruit\">Se connecter</a>\r\n                </p>\r\n\r\n            </div>\r\n\r\n\r\n        </section>\r\n    </th:block>\r\n    <script>\r\n        function togglePassword(inputId) {\r\n            const input = document.getElementById(inputId);\r\n            const icon = document.getElementById(\"eyeIcon\");\r\n\r\n            const open = icon.dataset.open;\r\n            const close = icon.dataset.close;\r\n\r\n            if (input.type === 'password') {\r\n                input.type = 'text';\r\n                icon.src = close;\r\n            } else {\r\n                input.type = 'password';\r\n                icon.src = open;\r\n            }\r\n        }\r\n        function checkStrength(pwd) {\r\n            const bar  = document.getElementById('strengthBar');\r\n            const text = document.getElementById('strengthText');\r\n            let score  = 0;\r\n            if (pwd.length >= 6)  score++;\r\n            if (pwd.length >= 10) score++;\r\n            if (/[A-Z]/.test(pwd)) score++;\r\n            if (/[0-9]/.test(pwd)) score++;\r\n            if (/[^A-Za-z0-9]/.test(pwd)) score++;\r\n\r\n            const levels = [\r\n                {color:'#e74c3c', label:'Très faible', width:'20%'},\r\n                {color:'#e67e22', label:'Faible',      width:'40%'},\r\n                {color:'#f1c40f', label:'Moyen',       width:'60%'},\r\n                {color:'#2ecc71', label:'Fort',        width:'80%'},\r\n                {color:'#27ae60', label:'Très fort',   width:'100%'},\r\n            ];\r\n            const lvl = levels[Math.min(score, 4)];\r\n            bar.style.width      = lvl.width;\r\n            bar.style.background = lvl.color;\r\n            text.textContent     = lvl.label;\r\n            text.style.color     = lvl.color;\r\n        }\r\n    </script>\r\n</main>\r\n\r\n</body>\r\n</html>
